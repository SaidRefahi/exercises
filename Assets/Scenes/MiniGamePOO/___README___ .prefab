  m_Script: {fileID: 11500000, guid: 2528d50a14eba0c4abfe3aafdf2a2b70, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Utilities.LevelReadme
  levelName: OOP Pillars Minigame
  description: 'A mini-game designed to showcase the core pillars of Object-Oriented
    Programming: Abstraction, Encapsulation, Inheritance, and Polymorphism. It uses
    pure C# classes (Ability, HealBeam, DamageBeam) interacting with MonoBehaviours
    (Entity, FriendObj, EnemyObj) to elegantly separate core logic from Unity''s
    presentation layer. The goal is to heal the ally to full health and defeat the
    enemy before the 15-second timer runs out.'
  controls: 'H: Cast Heal Beam on the Ally.

    A: Cast Damage Beam on the Enemy.'
