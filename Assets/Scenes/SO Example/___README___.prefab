  m_Script: {fileID: 11500000, guid: 2528d50a14eba0c4abfe3aafdf2a2b70, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Utilities.LevelReadme
  levelName: Scriptable Objects & Polymorphism
  description: This scene demonstrates the power of ScriptableObjects combined with
    polymorphism to create a flexible, data-driven behavior system. A base Behavior
    class is inherited by specific, modular behaviors (MoveBehavior, DestroyBehavior,
    SpawnCubeBehavior). A central executor on the GameObject reads the assigned ScriptableObject
    and executes it via polymorphism, completely avoiding tight coupling. This perfectly
    adheres to SOLID principles and the 'Data-Driven' rule of the engineering manifesto.
  controls: 'Spacebar: Execute the assigned behavior (Note: The MoveBehavior executes
    automatically every frame).'
