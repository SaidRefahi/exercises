  m_Script: {fileID: 11500000, guid: 2528d50a14eba0c4abfe3aafdf2a2b70, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Utilities.LevelReadme
  levelName: First-Person Builder & Object Pooling
  description: ' A first-person controller showcasing high-performance memory management
    via native UnityEngine.Pool.ObjectPool. The scene implements an interface-driven
    interaction system (IInteractable) and strict Zero GC rules. Players can pick
    up cubes, storing them in a lightweight integer-based inventory, and dynamically
    place them flush against surfaces using raycast normals to build custom platforms
    or stairs.'
  controls: 'WASD: Move

    Space: Jump

    Mouse: Look around

    E: Interact
    / Pick up cube

    Left-Click: Place cube from inventory onto a targeted surface'
