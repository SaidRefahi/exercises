  m_Script: {fileID: 11500000, guid: 2528d50a14eba0c4abfe3aafdf2a2b70, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Utilities.LevelReadme
  levelName: Advanced Third-Person Controller
  description: A lightweight, robust Third-Person Controller heavily utilizing native
    Unity tools. It integrates Cinemachine for buttery-smooth camera tracking and
    the event-driven Input System. It features an intelligent Lock-On mechanic that
    uses Physics.OverlapSphere to find the nearest enemy and dynamically adjusts
    the player's rotation to face the target. Engineered with strict Zero GC allocations
    on update loops.
  controls: 'WASD: Move

    Space: Jump

    Mouse: Rotate Camera

    C: Toggle
    Target Lock-On (requires an enemy in the "Enemy" layer nearby)'
