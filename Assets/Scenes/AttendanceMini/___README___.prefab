  m_Script: {fileID: 11500000, guid: 2528d50a14eba0c4abfe3aafdf2a2b70, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Utilities.LevelReadme
  levelName: Attendance MiniGame
  description: This level tests recursive algorithms and short-term memory. The manager
    script uses a recursive coroutine to iterate through an array of generated students,
    dynamically highlighting them in green (attended) or red (absent). After the
    sequence, the player has 5 seconds to input the exact number of attendees. Built
    with a focus on Coroutine sequencing and robust array state management.
  controls: Press once for every student you remember attending (e.g., if 4 attended,
    press Space 4 times before the 5-second timer ends)
